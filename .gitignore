# ===================================
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env*.local

# ===================================
# TypeScript / Turbopack cache
# ===================================
**/*.tsbuildinfo
**/.turbo/

# ===================================
